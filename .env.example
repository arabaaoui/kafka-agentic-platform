# kafka-agentic-platform — environment variables
# Copy to .env and fill in your values.  Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://platform:platform@localhost:5432/platform
DATABASE_URL_SYNC=postgresql://platform:platform@localhost:5432/platform  # alembic

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM provider ─────────────────────────────────────────────────────────────
# LiteLLM routes to Gemini (primary) or Claude (fallback)
LITELLM_API_KEY=changeme
GOOGLE_ADK_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=

# ── Observability (Langfuse self-hosted) ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SECRET_KEY=sk-lf-changeme
LANGFUSE_HOST=http://localhost:3001

# ── Tenant kubeconfigs ───────────────────────────────────────────────────────
KUBECONFIG_PREPROD=/path/to/kubeconfig-preprod
KUBECONFIG_PROD=/path/to/kubeconfig-prod

# ── MCP servers ──────────────────────────────────────────────────────────────
MCP_C4_ATLASSIAN_URL=http://localhost:3010/sse   # c4-atlassian MCP server

# ── Jira (via MCP c4-atlassian) ──────────────────────────────────────────────
JIRA_BASE_URL=https://jira.carrefour.com
JIRA_TOKEN=changeme

# ── API settings ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ── Tenants dir ───────────────────────────────────────────────────────────────
TENANTS_DIR=tenants

# ── Language policy (ADR-005) ─────────────────────────────────────────────────
# Controls the output language of agent reports (audit.md, BRIEF.md, KB cards).
# Supported values: "en" (default) | "fr"
# Internal reasoning and PromQL always stay in English regardless.
# See docs/adr/0005-language-policy.md
PLATFORM_LANG=fr

# ── RAG Semantic Search (ADR-009) ──────────────────────────────────────────────
# Controls the scope of RAG search ("kb", "audit", or "kb,audit")
RAG_SCOPE=kb,audit
# Name of the sentence-transformer model on Hugging Face Hub
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
# Local path inside the container where the model is stored
EMBEDDING_MODEL_PATH=/models/multilingual-e5-small
